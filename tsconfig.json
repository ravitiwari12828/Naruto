{
  "ts-node": {
    "transpileOnly": true,
    "esm": false,
    "compiler": "typescript",
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "ES2020",
    "strict": false,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.js", "./**/*.ts"],
  "exclude": ["node_modules", "dist", "data"]
}
