{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "ES2020",
    "strict": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "ts-node": {
    "transpileOnly": true,
    "skipProject": false
  },
  "include": ["**/*.js", "**/*.ts"],
  "exclude": ["node_modules", "dist", "data"]
}
