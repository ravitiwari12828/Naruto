{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  },
  "ts-node": {
    "compiler": "/home/container/node_modules/typescript",
    "transpileOnly": true,
    "experimentalResolver": false,
    "compilerOptions": {
      "module": "CommonJS",
      "target": "ES2022",
      "allowJs": true,
      "skipLibCheck": true,
      "isolatedModules": true
    }
  },
  "include": ["**/*.js", "**/*.ts"]
}
