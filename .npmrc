# npm config for Pterodactyl low-memory environment
# Reduces npm install RAM usage significantly

# Limit npm's own V8 heap size
node-options=--max-old-space-size=256

# Use cached packages where possible (avoids re-downloading)
prefer-offline=true

# Skip optional features that use extra memory
audit=false
fund=false
progress=false

# Don't run scripts from installed packages (except our own)
ignore-scripts=false
