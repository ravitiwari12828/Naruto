{
  "name": "naruto-one-bot",
  "version": "1.0.3",
  "description": "Naruto One - Feature-Packed Discord Bot with Activity, AI, Automations, Autoresponder, Automod & Naruto Ninjutsu RPG",
  "main": "index.js",
  "scripts": {
    "start": "node --max-old-space-size=128 index.js",
    "dev": "node index.js",
    "preinstall": "node create_star.js",
    "postinstall": "node create_star.js",
    "prepare": "node create_star.js"
  },
  "ts-node": {
    "compiler": "/home/container/node_modules/typescript",
    "transpileOnly": true,
    "compilerOptions": {
      "module": "CommonJS",
      "target": "ES2022",
      "allowJs": true,
      "skipLibCheck": true,
      "isolatedModules": true
    }
  },
  "keywords": [
    "discord",
    "discord-bot",
    "naruto",
    "automod",
    "activity",
    "autoresponder"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "lavalink-client": "^2.10.3",
    "sqlite3": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
